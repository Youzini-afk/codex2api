# ============================================================
# Codex2API Zeabur 环境变量示例
# 推荐用于 Zeabur 单服务自动部署
# ============================================================

# 管理后台登录密钥（强烈建议设置）
ADMIN_SECRET=change-this-before-production

# 如未接入 PostgreSQL / Redis，Zeabur 环境下会自动回退到：
# - SQLite: /data/codex2api.db
# - Memory Cache
#
# 如果你想显式固定轻量模式，也可以取消注释以下配置：
# DATABASE_DRIVER=sqlite
# DATABASE_PATH=/data/codex2api.db
# CACHE_DRIVER=memory

# 如果你在 Zeabur 中额外挂了 PostgreSQL / Redis，可直接绑定这些变量：
# DATABASE_URL=${POSTGRES_CONNECTION_STRING}
# REDIS_URL=${REDIS_CONNECTION_STRING}

# 也兼容分拆变量形式，例如：
# DATABASE_HOST=${POSTGRESQL_HOST}
# DATABASE_PORT=${POSTGRES_PORT}
# DATABASE_USER=${POSTGRESQL_USERNAME}
# DATABASE_PASSWORD=${POSTGRES_PASSWORD}
# DATABASE_NAME=${POSTGRES_DATABASE}
# REDIS_ADDR=${REDIS_HOST}:${REDIS_PORT}
# REDIS_PASSWORD=${REDIS_PASSWORD}

# 时区（可选）
TZ=Asia/Shanghai
